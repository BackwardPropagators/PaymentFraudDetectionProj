def _make_cached_predictor(fold_predictions, key, n_folds):
    preds = [fold_predictions[i + 1][key] for i in range(n_folds)]
    call_idx = [0]
    def predictor(train_idx, test_idx):
        result = preds[call_idx[0]]
        call_idx[0] += 1
        return result
    return predictor

